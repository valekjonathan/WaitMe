# WaitMe Automation Bridge — Variables de entorno
# Copiar a .env y rellenar valores reales

PORT=3000

# GitHub Webhook (Settings → Webhooks → Add webhook → Secret)
GITHUB_WEBHOOK_SECRET=

# GitHub API (para leer docs/devcontext del repo; rate limit mayor con token)
GITHUB_TOKEN=

# OpenAI (para Agents SDK / ChatGPT; futuro)
OPENAI_API_KEY=

# Repo a leer
REPO_OWNER=valekjonathan
REPO_NAME=WaitMe

# URL del bridge desplegado (para hooks locales)
BRIDGE_URL=https://waitme-bridge.onrender.com
