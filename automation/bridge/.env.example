# WaitMe Automation Bridge — Variables de entorno
# Copiar a .env y rellenar valores reales

PORT=3000

# GitHub Webhook secret (Settings → Webhooks → Add webhook → Secret)
GITHUB_WEBHOOK_SECRET=

# OpenAI API key (para Agents SDK)
OPENAI_API_KEY=

# URL del bridge (para Cursor hooks / ping)
BRIDGE_URL=http://localhost:3000
