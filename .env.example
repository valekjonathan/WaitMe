VITE_MAPBOX_TOKEN=PEGA_AQUI_EL_TOKEN
VITE_SENTRY_DSN=

# Para npm run supabase:migrate (Supabase CLI)
# SUPABASE_ACCESS_TOKEN=  # https://supabase.com/dashboard/account/tokens
# SUPABASE_PROJECT_REF=   # Project Settings → General (o se extrae de VITE_SUPABASE_URL)
# SUPABASE_DB_PASSWORD=   # Project Settings → Database

# Alternativa: npm run supabase:migrate:direct (conexión directa)
# SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
