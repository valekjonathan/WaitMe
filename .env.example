# Supabase (obligatorios para auth y datos)
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key

# Mapbox (obligatorio para el mapa) — https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=PEGA_AQUI_EL_TOKEN
VITE_SENTRY_DSN=

# DEV: diagnóstico pantalla negro/blanco (temporal)
# VITE_DISABLE_MAP=true       # Home renderiza bloque simple en vez del mapa
# VITE_DEV_BYPASS_AUTH=true  # Usa Supabase real en vez de mock
# VITE_CAPACITOR_SERVER_URL  # Para /dev-diagnostics (ej. http://192.168.0.15:5173)

# Para npm run supabase:migrate (Supabase CLI)
# SUPABASE_ACCESS_TOKEN=  # https://supabase.com/dashboard/account/tokens
# SUPABASE_PROJECT_REF=   # Project Settings → General (o se extrae de VITE_SUPABASE_URL)
# SUPABASE_DB_PASSWORD=   # Project Settings → Database

# Alternativa: npm run supabase:migrate:direct (conexión directa)
# SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
