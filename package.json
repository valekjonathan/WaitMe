{
  "name": "waitme-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "predev": "rm -rf ios/App/App/public/assets 2>/dev/null || true",
    "dev": "vite --host --port 5173",
    "dev:auto": "chokidar \"src/**/*\" \"src/pages/**/*\" \"src/components/**/*\" \"src/lib/**/*\" \"src/system/**/*\" \"capacitor.config.ts\" \"package.json\" -c \"npm run ios:refresh\"",
    "build": "vite build",
    "lint": "eslint . --max-warnings=9999",
    "lint:fix": "eslint . --fix",
    "lint:fast": "biome check src tests",
    "test": "vitest run",
    "test:all": "playwright test && VITE_SAFE_MODE=true playwright test tests/smoke/safe-mode.spec.js",
    "test:safe-mode": "VITE_SAFE_MODE=true playwright test tests/smoke/safe-mode.spec.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:contracts": "vitest run tests/contracts",
    "test:ui": "playwright test --ui",
    "test:visual": "percy exec -- playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run build",
    "export-codebase": "node scripts/export-codebase.js",
    "export-zip": "bash scripts/export-zip-safe.sh",
    "ship": "bash scripts/ship.sh",
    "prepare": "husky",
    "preview": "vite preview --host --port 4173",
    "ios:auto": "bash scripts/dev-ios.sh",
    "start": "concurrently \"npm run dev\" \"npm run dev:auto\"",
    "ios:fresh": "bash scripts/ios-fresh.sh",
    "ios:dev": "npm run ios:fresh",
    "ios:live": "bash scripts/ios-live.sh",
    "ios:watch": "bash scripts/ios-watch.sh",
    "ios:refresh": "bash scripts/ios-refresh.sh",
    "devcontext:update": "bash scripts/devcontext-update.sh",
    "ios:clean": "rm -rf dist ios/App/App/public ios/App/DerivedData 2>/dev/null || true",
    "ios:reload": "rm -rf dist && npm run build && npx cap sync ios && npx cap run ios --target=\"iPhone 16e\"",
    "ios:logs": "xcrun simctl spawn booted log stream --level debug",
    "ios:sync:dev": "npm run build && CAPACITOR_USE_DEV_SERVER=true npx cap sync ios",
    "ios:sync": "npm run build && npx cap sync ios",
    "ios:open": "npx cap open ios",
    "ios:reset": "bash scripts/ios-reset.sh",
    "ios:run": "bash scripts/ios-run.sh",
    "ios:run:dev": "CAPACITOR_USE_DEV_SERVER=true npx cap run ios",
    "supabase:migrate": "bash scripts/supabase-migrate.sh",
    "supabase:migrate:direct": "node scripts/run-profile-migration.mjs",
    "db:migrate:print": "node -e \"const fs=require('fs');const p='supabase/migrations';const files=fs.readdirSync(p).filter(f=>f.endsWith('.sql')).sort().reverse();const last=files[0];console.log(fs.readFileSync(p+'/'+last,'utf8'));\"",
    "diagnose": "node scripts/diagnose-project.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "audit:repo": "knip",
    "check:fast": "npm run build && npm run test:e2e tests/smoke/load.spec.js",
    "dev:safe": "VITE_SAFE_MODE=true vite --host --port 5173",
    "env:guard": "bash scripts/environment-guard.sh",
    "pwa:validate": "node scripts/pwa-icon-validator.mjs",
    "supabase:redirect-urls": "node scripts/print-supabase-redirect-urls.js",
    "supabase:ensure-oauth-ios": "node scripts/ensure-oauth-redirect-ios.js",
    "cleanup:tests": "bash scripts/test-cleanup.sh",
    "cleanup:dev": "bash scripts/dev-cleanup.sh"
  },
  "dependencies": {
    "@capacitor/app": "^8.0.1",
    "@capacitor/browser": "^8.0.1",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/inappbrowser": "^3.0.2",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@sentry/react": "^10.42.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.84.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "framer-motion": "^11.16.4",
    "lucide-react": "^0.475.0",
    "mapbox-gl": "^3.19.1",
    "ngeohash": "^0.6.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.26.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@chromatic-com/storybook": "^5.0.1",
    "@eslint/js": "^9.19.0",
    "@percy/cli": "^1.31.9",
    "@percy/playwright": "^1.0.10",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.2.15",
    "@storybook/addon-docs": "^10.2.15",
    "@storybook/addon-onboarding": "^10.2.15",
    "@storybook/addon-vitest": "^10.2.15",
    "@storybook/react-vite": "^10.2.15",
    "@types/node": "^22.13.5",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/browser-playwright": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "knip": "^5.85.0",
    "lint-staged": "^15.4.3",
    "percy": "^5.0.0",
    "pg": "^8.20.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "prop-types": "^15.8.1",
    "sharp": "^0.34.5",
    "storybook": "^10.2.15",
    "supabase": "^2.76.16",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^6.1.0",
    "vitest": "^4.0.18"
  }
}
